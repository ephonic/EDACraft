#===========================================================================
# Layer 4: RTL-to-DSL Reference
#===========================================================================

# Reference Verilog → DSL module mapping:
#   ref_rtl/LDPC_Decoder/  →  skills/codec/ldpc/dsl_modules.py  (WiMax LDPC)

#===========================================================================
# Template Registry
#===========================================================================

_template_map = {
    "ldpc_decoder": ldpc_decoder_cycle,
    "varnode": varnode_cycle,
    "checknode": checknode_cycle,
}

for _name, _tmpl in _template_map.items():
    TemplateRegistry.register(_name, _tmpl)
