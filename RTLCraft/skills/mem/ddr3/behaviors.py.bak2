#===========================================================================
# Layer 4: RTL-to-DSL Reference
#===========================================================================

# Reference Verilog → DSL module mapping:
#   ref_rtl/core_ddr3_controller/  →  skills/mem/ddr3/dsl_modules.py  (Lightweight DDR3)

#===========================================================================
# Template Registry
#===========================================================================

_template_map = {
    "ddr3_ctrl": ddr3_ctrl_cycle,
    "dfi_seq": dfi_seq_cycle,
    "phy": phy_cycle,
}

for _name, _tmpl in _template_map.items():
    TemplateRegistry.register(_name, _tmpl)
