#===========================================================================
# Layer 4: RTL-to-DSL Reference
#===========================================================================

# Reference Verilog → DSL module mapping:
#   ref_rtl/cam/  →  skills/mem/cam/dsl_modules.py  (Forencich CAM)

#===========================================================================
# Template Registry
#===========================================================================

_template_map = {
    "camsrl": camsrl_cycle,
    "cambram": cambram_cycle,
    "priorityencoder": priorityencoder_cycle,
}

for _name, _tmpl in _template_map.items():
    TemplateRegistry.register(_name, _tmpl)
