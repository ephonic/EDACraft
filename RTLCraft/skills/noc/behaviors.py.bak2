#===========================================================================
# Layer 4: RTL-to-DSL Reference
#===========================================================================

# Reference Verilog → DSL module mapping:
#   ref_rtl/NoC/  →  skills/noc/dsl_modules.py  (2D mesh NoC)

#===========================================================================
# Template Registry
#===========================================================================

_template_map = {
    "router": router_cycle,
    "buffer": buffer_cycle,
    "crossbar": crossbar_cycle,
    "network": network_cycle,
}

for _name, _tmpl in _template_map.items():
    TemplateRegistry.register(_name, _tmpl)
