#===========================================================================
# Layer 4: RTL-to-DSL Reference
#===========================================================================

# Reference Verilog → DSL module mapping:
#   ref_rtl/interfaces/axi/  →  skills/interfaces/axi/dsl_modules.py  (Forencich AXI)

#===========================================================================
# Template Registry
#===========================================================================

_template_map = {
    "axi_arbiter": axi_arbiter_cycle,
    "axi_crossbar": axi_crossbar_cycle,
    "axi_register": axi_register_cycle,
}

for _name, _tmpl in _template_map.items():
    TemplateRegistry.register(_name, _tmpl)
