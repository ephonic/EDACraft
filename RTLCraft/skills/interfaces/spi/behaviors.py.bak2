#===========================================================================
# Layer 4: RTL-to-DSL Reference
#===========================================================================

# Reference Verilog → DSL module mapping:
#   ref_rtl/interfaces/spi/  →  skills/interfaces/spi/dsl_modules.py  (Cadence SPI)

#===========================================================================
# Template Registry
#===========================================================================

_template_map = {
    "spi_master": spi_master_cycle,
    "spi_slave": spi_slave_cycle,
    "spi_controller": spi_controller_cycle,
}

for _name, _tmpl in _template_map.items():
    TemplateRegistry.register(_name, _tmpl)
