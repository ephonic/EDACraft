section res_metal
 
// **********************************     Metal 1 with W/S=0.045/0.135     ***********************************
subckt rm1l ( n1 n2 ) 
parameters l=1u w=1u factor=factor_res_metal multi=1 rsh=r_rm1l dw=0 pvc1=0 
+ pvc2=0 ptc1=1.78e-03 ptc2=-1.94e-07 pt=temp tfac=1.0 + ptc1 * (pt - 25.0) + 
+ ptc2 * (pt - 25.0) * (pt - 25.0) 
r1 ( n1 n2 ) resistor r=rsh / multi * l * factor / (w * factor - dw) * (1 + pvc1 
+ * (abs(v(n2,n1)) / l / factor) + pvc2 * (v(n2,n1) / l / factor) * (v(n2,n1) / 
+ l / factor)) * tfac
ends rm1l
 
// **********************************     Metal 1 with W/S=0.045/0.045     ***********************************
subckt rm1s ( n1 n2 ) 
parameters l=1u w=1u factor=factor_res_metal multi=1 rsh=r_rm1s dw=0 pvc1=0 
+ pvc2=0 ptc1=1.75e-03 ptc2=-3.73e-07 pt=temp tfac=1.0 + ptc1 * (pt - 25.0) + 
+ ptc2 * (pt - 25.0) * (pt - 25.0) 
r1 ( n1 n2 ) resistor r=rsh / multi * l * factor / (w * factor - dw) * (1 + pvc1 
+ * (abs(v(n2,n1)) / l / factor) + pvc2 * (v(n2,n1) / l / factor) * (v(n2,n1) / 
+ l / factor)) * tfac
ends rm1s
 
