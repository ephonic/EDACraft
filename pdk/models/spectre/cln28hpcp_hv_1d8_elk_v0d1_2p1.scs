+ kvsatody * rho_ueffrefsody + kvsatody1 * rho_ueffrefsody1) * oseflag) fvsat_odod=fvsat_odod_nu  
+ / fvsat_odod_dn fvsat_spomt1_nu=max((1 + (kvsatspom1 * rho_ueffspomt1) * mbeflag  
