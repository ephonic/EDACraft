+ da0_dp=kdpa_a0 * dinv_sap + kdp2a_a0 * dinv_sapb  
parameters da0_enxy=kenx_a0 * dinv_enx + keny_a0 * dinv_eny + keny1_a0 * dinv_eny1  
+ da0_lod=da0_dp * pseflag + da0_enxy * ceslflag deta0_sa=((steta0 / pow(kstress_vth0,lodeta0)  
+ + steta00 * pow(kstress_vth00,lodeta00)) * (inv_sa + inv_sb - inv_saref - inv_sbref)  
+ + steta01 * pow(kstress_vth01,lodeta01) * (inv_sa1 + inv_sb1 - inv_saref1 - inv_sbref1)  
