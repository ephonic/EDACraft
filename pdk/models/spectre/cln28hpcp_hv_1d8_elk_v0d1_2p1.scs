+ + kvsatdp2a * rho_ueffrefdp2a) * pseflag) fvsat_dp=fvsat_dp_nu / fvsat_dp_dn fvsat_enxy_nu=(1  
+ + (kvsatenx * rho_ueffenx + kvsateny * rho_ueffeny + kvsateny1 * rho_ueffeny1  
+ + selmin(kvsatrx * rho_ueffrex,kvsatenx * rho_ueffenx) + selmin(kvsatry *  
