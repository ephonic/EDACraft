+ * pow(lef * 1e6,e_3_2) + f_3_1 * pow(wef * 1e6,f_3_2) + g_3_1 * pow(lef * 1e6  
+ * wef * 1e6,g_3_2)) ratio_wl_t=1 * _bidirectionflag + ratio_f1 * (1 - _bidirectionflag)  
+ ratio_wl_d=ratio_f2 * _bidirectionflag + ratio_f3 * (1 - _bidirectionflag) ratio_wl=ratio_wl_d  
+ * _designflag + ratio_wl_t * (1 - _designflag) ratio_f4=min(1,a_4 + b_4 / (lef  
+ * 1e6) + c_4 / (wef * 1e6) + d_4 / (lef * 1e6 * wef * 1e6) + e_4_1 * pow(lef *  
+ 1e6,e_4_2) + f_4_1 * pow(wef * 1e6,f_4_2) + g_4_1 * pow(lef * 1e6 * wef * 1e6,g_4_2))  
+ ratio_f5=min(1,a_5 + b_5 / (lef * 1e6) + c_5 / (wef * 1e6) + d_5 / (lef * 1e6  
+ * wef * 1e6) + e_5_1 * pow(lef * 1e6,e_5_2) + f_5_1 * pow(wef * 1e6,f_5_2) + g_5_1  
+ * pow(lef * 1e6 * wef * 1e6,g_5_2)) ratio_global=(ratio_f4 * _bidirectionflag  
+ + ratio_f5 * (1 - _bidirectionflag)) * globalflag * global_factor_hv18 * sigma_factor_hv18  
