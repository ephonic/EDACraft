+ + deta0_spmb) * selmbeb deta0_lod=deta0_sa * lodflag + deta0_dp * pseflag + deta0_enxy  
+ * ceslflag + deta0_odod * oseflag + deta0_mbe * mbeflag + keta0we * (sca + web_mac  
+ * scb + wec_mac * scc) * wpeflag dk2_lod=((stk2 / pow(kstress_vth0,lodk2) + stk20  
+ * pow(kstress_vth00,lodk20)) * (inv_sa + inv_sb - inv_saref - inv_sbref) + stk21  
+ * pow(kstress_vth01,lodk21) * (inv_sa1 + inv_sb1 - inv_saref1 - inv_sbref1) +  
+ (stk22 / pow(kstress_vth02,lodk22) + stk202 * pow(kstress_vth002,lodk202)) * (inv_sa2  
+ + inv_sb2 - inv_saref2 - inv_sbref2) + (stk23 / pow(kstress_vth03,lodk23) + stk203  
+ * pow(kstress_vth003,lodk203)) * (inv_sa3 + inv_sb3 - inv_saref3 - inv_sbref3))  
+ * lodflag * rllod  
real selmin(real par1_hv, real par2_hv)  {  
 return abs(par1_hv)<abs(par2_hv) ? par1_hv : (par2_hv*-1); 
}     
  
  
