+ + steta003 * pow(kstress_vth003,lodeta003)) * (inv_sa3 + inv_sb3 - inv_saref3  
+ - inv_sbref3)) * rllod deta0_dp=kdpc_eta0 * dinv_spa + kdpl_eta0 * dinv_spa1 +  
+ kdpx_eta0 * dinv_spa2 + kdps_eta0 * dinv_spa3 + kdpa_eta0 * dinv_sap + kdp2_eta0  
+ * dinv_spba + kdp2l_eta0 * dinv_spba1 + kdp2a_eta0 * dinv_sapb deta0_enxy=kenx_eta0  
