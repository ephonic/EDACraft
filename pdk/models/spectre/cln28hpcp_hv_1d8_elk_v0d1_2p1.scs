+ * (inv_sa2 + inv_sb2 - inv_saref2 - inv_sbref2) + (steta03 / pow(kstress_vth03,lodeta03)  
+ + steta003 * pow(kstress_vth003,lodeta003)) * (inv_sa3 + inv_sb3 - inv_saref3  
+ - inv_sbref3)) * rllod deta0_dp=kdpc_eta0 * dinv_spa + kdpl_eta0 * dinv_spa1 +  
+ kdpx_eta0 * dinv_spa2 + kdps_eta0 * dinv_spa3 + kdpa_eta0 * dinv_sap + kdp2_eta0  
+ * dinv_spba + kdp2l_eta0 * dinv_spba1 + kdp2a_eta0 * dinv_sapb deta0_enxy=kenx_eta0  
+ * dinv_enx + keny_eta0 * dinv_eny + keny1_eta0 * dinv_eny1 + krex_eta0 * dinv_rex  
+ + krey_eta0 * dinv_rey deta0_odod=ksodx_eta0 * dinv_sodx + ksodx1_eta0 * (dinv_sodx1  
+ + dinv_sodx2) + ksodx3_eta0 * dinv_sodx3 + ksodx4_eta0 * dinv_sodx4 + ksody_eta0  
+ * dinv_sody + ksody1_eta0 * dinv_sody1 deta0_spomt1=(steta0spom1 * pow(kspom1_vth0,spom1eta0))  
+ * (inv_spomt1 - inv_spom1ref) deta0_spomb1=(steta0spom1 * pow(kspom1_vth0,spom1eta0))  
+ * (inv_spomb1 - inv_spom1ref) deta0_spmt=(steta0spm * pow(kspm_vth0,spmeta0))  
+ * (inv_spmt - inv_spmref) deta0_spmb=(steta0spm * pow(kspm_vth0,spmeta0)) * (inv_spmb  
+ - inv_spmref) deta0_mbe=(deta0_spomt1 + deta0_spmt) * selmbet + (deta0_spomb1  
+ + deta0_spmb) * selmbeb deta0_lod=deta0_sa * lodflag + deta0_dp * pseflag + deta0_enxy  
+ * ceslflag + deta0_odod * oseflag + deta0_mbe * mbeflag + keta0we * (sca + web_mac  
+ * scb + wec_mac * scc) * wpeflag dk2_lod=((stk2 / pow(kstress_vth0,lodk2) + stk20  
+ * pow(kstress_vth00,lodk20)) * (inv_sa + inv_sb - inv_saref - inv_sbref) + stk21  
+ * pow(kstress_vth01,lodk21) * (inv_sa1 + inv_sb1 - inv_saref1 - inv_sbref1) +  
+ (stk22 / pow(kstress_vth02,lodk22) + stk202 * pow(kstress_vth002,lodk202)) * (inv_sa2  
+ + inv_sb2 - inv_saref2 - inv_sbref2) + (stk23 / pow(kstress_vth03,lodk23) + stk203  
+ * pow(kstress_vth003,lodk203)) * (inv_sa3 + inv_sb3 - inv_saref3 - inv_sbref3))  
+ * lodflag * rllod  
real selmin(real par1_hv, real par2_hv)  {  
 return abs(par1_hv)<abs(par2_hv) ? par1_hv : (par2_hv*-1); 
}     
  
  
