+ / fu0_odod_dn fu0_spomt1_nu=max((1 + rho_ueffspomt1 * mbeflag * selmbet),mbe_clamp)  
+ fu0_spomt1_dn=max((1 + rho_ueffrefspom1 * mbeflag * selmbet),mbe_clamp) fu0_spomt1=fu0_spomt1_nu  
+ / fu0_spomt1_dn fu0_spomb1_nu=max((1 + rho_ueffspomb1 * mbeflag * selmbeb),mbe_clamp)  
+ fu0_spomb1_dn=max((1 + rho_ueffrefspom1 * mbeflag * selmbeb),mbe_clamp) fu0_spomb1=fu0_spomb1_nu  
+ / fu0_spomb1_dn fu0_spmt_nu=max((1 + rho_ueffspmt * mbeflag * selmbet),mbe_clamp)  
+ fu0_spmt_dn=max((1 + rho_ueffrefspm * mbeflag * selmbet),mbe_clamp) fu0_spmt=fu0_spmt_nu  
+ / fu0_spmt_dn fu0_spmb_nu=max((1 + rho_ueffspmb * mbeflag * selmbeb),mbe_clamp)  
+ fu0_spmb_dn=max((1 + rho_ueffrefspm * mbeflag * selmbeb),mbe_clamp) fu0_spmb=fu0_spmb_nu  
+ / fu0_spmb_dn fu0_mbe=fu0_spomt1 * fu0_spomb1 * fu0_spmt * fu0_spmb fu0_lod=max(1e-1,fu0_sa  
+ * fu0_dp * fu0_enxy * fu0_odod * fu0_mbe) fvsat_sa_nu=max((1 + (kvsat * rho_ueff  
+ + kvsat1 * rho_ueff1 + kvsat2 * rho_ueff2 + kvsat3 * rho_ueff3) * rllod * lodflag),lod_clamp)  
+ fvsat_sa_dn=max((1 + (kvsat * rho_ueffref + kvsat1 * rho_ueffref1 + kvsat2 * rho_ueffref2  
+ + kvsat3 * rho_ueffref3) * rllod * lodflag),lod_clamp) fvsat_sa=fvsat_sa_nu /  
+ fvsat_sa_dn fvsat_dp_nu=(1 + (kvsatdpc * rho_ueffdpc + kvsatdpl * rho_ueffdpl  
+ + kvsatdps * rho_ueffdps + kvsatdpx * rho_ueffdpx + kvsatdpa * rho_ueffdpa) *  
+ pseflag) * (1 + (kvsatdp2 * rho_ueffdp2 + kvsatdp2l * rho_ueffdp2l + kvsatdp2a  
+ * rho_ueffdp2a) * pseflag) fvsat_dp_dn=(1 + (kvsatdpc * rho_ueffrefdpc + kvsatdpl  
+ * rho_ueffrefdpl + kvsatdps * rho_ueffrefdps + kvsatdpx * rho_ueffrefdpx + kvsatdpa  
