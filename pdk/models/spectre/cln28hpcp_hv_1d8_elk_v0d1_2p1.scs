+ * fac1 dxln_hv18_ms_local=b * geo_fac * lef * fac2 dxwn_hv18_ms_local= - b * geo_fac  
+ * wef * fac3 dvthn_hv18_ms_local=(a * geo_fac + ((1 / sqrt(multi * nf)) * avtgm_min  
+ * mismatchflag * local_factor_hv18 * sigma_factor_hv18)) * fac4 fu0n_hv18_ms_local=max(e_limit1,min(e_limit2,1  
+ + e * geo_fac * fac5 * (1 - totalflag))) lmonte_flagn_hv18_ms=1 / sqrt(multi *  
+ nf) * fac5 * mismatchflag * local_factor_hv18 * sigma_factor_hv18 * (1 - totalflag)  
+ _bidirectionflag=1 _designflag=1 a_1=1 b_1=0 c_1=0 d_1=0 e_1_1=0 e_1_2=0 f_1_1=0  
+ f_1_2=0 g_1_1=0 g_1_2=0 a_2=1 b_2=0 c_2=0 d_2=0 e_2_1=0 e_2_2=0 f_2_1=0 f_2_2=0  
+ g_2_1=0 g_2_2=0  
  
  
