+ + 1e-9) * (4e-5 - 2.0e-5 + lef)) / factor rey=sqrt((eny2 * factor + 1e-9) * (4e-5  
+ - 2.0e-5 + lef)) / factor sodx=0.18e-6 / factor sodxa=sodx sodxb=sodx sodx1=pow((sa5  
+ * factor + 1.0e-7) * sqrt(sodx * factor),2 / 3) / factor sodx2=pow((pow(1e-6,3)  
+ + 10 * pow(sa6 * factor,3)) * sqrt(sodx * factor),2 / 7) / factor sodx4=pow(pow(sa7  
+ * factor + 1.0e-9,3) * sqrt(sodx * factor),2 / 7) / factor sody=0.5085e-6 / factor  
+ spmt=spmref / factor spomt=spomref / factor spomt1=1 / pow((pow(spomt * factor,0.5)  
+ / pow(spmt * factor,1) + 1e-30),2) / factor spmb=spmref / factor spomb=spomref  
+ / factor spomb1=1 / pow((pow(spomb * factor,0.5) / pow(spmb * factor,1) + 1e-30),2)  
+ / factor _conum=max(1,int(((wef / factor - 0.0945 * 1e-6 * 2 / factor) - 0.036  
+ * 1e-6 / factor) / (0.1125 * 1e-6 / factor) + 1)) _rc_nrsd=80 / 18.5 / _conum  
+ / nf _delvto=0 _mulu0=1 _ccoflag=ccoflag_hv18 _rcoflag=rcoflag_hv18 _rgflag=rgflag_hv18  
+ mismatchflag=mismatchflag_mos_hv18 globalflag=globalflag_mos_hv18 totalflag=totalflag_mos_hv18  
+ lef=(l) * factor wef=(w / nf) * factor temp1=plo_tox_hv temp2=plo_dxl_hv temp3=plo_dxw_hv  
+ temp4=parl1_hv temp5=parl2_hv mis_a_1=0.0044 mis_a_2=-0.55 mis_a_3=0.1 mis_b_1=0.0025  
+ mis_b_2=0.9 mis_b_3=0.12 mis_c_1=0.95 mis_c_2=0 mis_c_3=0 mis_d_1=0.0016 mis_d_2=0  
+ mis_d_3=0 mis_e_1=0.007 mis_e_2=-1.2 mis_e_3=0.12 e_limit1=0.1 e_limit2=2 avtgm_min=0  
+ a=mis_a_1 * pow(abs(lef * 1e6),mis_a_2) * pow(abs(wef * 1e6),mis_a_3) b=mis_b_1  
+ * pow(abs(lef * 1e6),mis_b_2) * pow(abs(wef * 1e6),mis_b_3) c=mis_c_1 * pow(abs(lef  
+ * 1e6),mis_c_2) * pow(abs(wef * 1e6),mis_c_3) d=mis_d_1 * pow(abs(lef * 1e6),mis_d_2)  
+ * pow(abs(wef * 1e6),mis_d_3) e=mis_e_1 * pow(abs(lef * 1e6),mis_e_2) * pow(abs(wef  
+ * 1e6),mis_e_3) fac1=temp1 fac2=temp2 fac3=temp3 fac4=temp4 fac5=c * temp4 + sqrt(1  
+ - c * c) * temp5 geo_fac=1 / sqrt(multi * nf * lef * wef * 1e12) * mismatchflag  
