###	Usage: magnet_placement    # Run magnet_placement
###	        [-move_fixed]          (allow fixed cells to be moved)
###	        [-mark_fixed]          (mark cells as fixed after placement)
###	        [-avoid_soft_blockages]
###	                               (dont allow cells to be placed over soft blockages)
###	        [-stop_by_sequential_cells]
###	                               (don't pull sequential cells)
###	        [-exclude_buffers]     (skip through buffers in levels)
###	        [-exclude_cells list]  (list of excluded cells list)
###	        [-logical_level level] (number of logic levels to pull)
###	        [-stop_points object_list]
###	                               (list of stop points where to stop magnetizing paths)
###	        [-cells list]          (list of cells)
###	        [-align]               (align the cells horizontally or vertically)
###	        magnet_objects         (a list of magnet objects)
