########################################################################################
######  DCICC FLOW - Version 4.6.0 (2016-10-19)
######  Owner : Anonymous , YaoXin
########################################################################################
###	define log file
set env(CDSLIB) default
set start_time [clock seconds]
set log_file_tail 0
set cur_shell_run_path	[pwd]
if {$synopsys_program_name == "dc_shell"} {
	set log_file dc.out
	while {[file isfile $log_file]} {
		incr log_file_tail 1
		set log_file dc.out.$log_file_tail
	}
	set_app_var sh_output_log_file $log_file
}
if {$synopsys_program_name == "icc_shell"} {
	set log_file icc.out
	while {[file isfile $log_file]} {
		incr log_file_tail 1
		set log_file icc.out.$log_file_tail
	}
	set_app_var sh_output_log_file $log_file
}
if {$synopsys_program_name == "pt_shell"} {
	if {$pt_shell_mode == "primetime_slave"} { cd .. }
}
###	select setup file
if {[file isfile setup_pt.tcl] && $synopsys_program_name == "pt_shell"} {
	puts "Script Info:: use local setup file : ./setup_pt.tcl"
	source ./setup_pt.tcl
} elseif {[file isfile ./setup.tcl]} {
	puts "Script Info:: use local setup file : ./setup.tcl"
	source ./setup.tcl
} else {
	puts "Script Info:: use default setup file : ../CMD/setup.tcl"
	source ../CMD/setup.tcl
}
if {$synopsys_program_name == "pt_shell"} {
	if {$pt_shell_mode == "primetime_master" || $pt_shell_mode == "primetime_slave"} { set var(use_mcmm_flow) true }
}
###	check version
########################################################################################
######	Library Setup
########################################################################################
set_app_var	sh_enable_page_mode			false
set_app_var	sh_new_variable_message			false
set_app_var	report_default_significant_digits	3

set nhp_predefine {
	ref_mw		""
	listdecap_cells	""
	actived_scenarios ""
	CDSLIB		""
	autofp		""
	process		""
	def_exists	""
	def_nonexists	""
	default_corner	""
	sl_design	0
	sl_clock	0
	sl_route	0
}

if {$synopsys_program_name == "icc_shell" && $designopt(spg) && [file isfile ./DC/out/$var(design_name).def]} {
	dict lappend nhp_predefine def_exists ./DC/out/$var(design_name).def
} else {
	foreach one_def $var(def) {
		if {[file isfile $one_def]} {
			dict lappend nhp_predefine def_exists $one_def
		} else {
			dict lappend nhp_predefine def_nonexists $one_def
		}
	}
}

unset -nocomplain nhp_clockdefine

if {[llength [glob -nocomplain .dcicchp.debug.*]]>0} {
	regexp -- {\.dcicchp\.debug\.(\S+)} [glob -nocomplain .dcicchp.debug.*] match debug_cdslib
	dict set nhp_predefine CDSLIB $debug_cdslib
} else {
	dict set nhp_predefine CDSLIB [lindex [split $env(CDSLIB) /] end]
}
if {![dict exists $tech_structure project_params [dict get $nhp_predefine CDSLIB]]} {
	puts [format "Script %s:: Design(%s) doesn't support! use default Tech(%s)." [string totitle error] \
			[dict get $nhp_predefine CDSLIB] [dict get $tech_structure project_params default process]]
	dict set nhp_predefine CDSLIB default
}
dict set nhp_predefine autofp [dict get $tech_structure project_params [dict get $nhp_predefine CDSLIB] autofp_script]
dict set nhp_predefine process [dict get $tech_structure project_params [dict get $nhp_predefine CDSLIB] process]
source [dict get $tech_structure process2file [dict get $nhp_predefine process] define_library]

set min_power_path      [format "%s%s" $synopsys_root "/minpower/syn"]
set_app_var search_path	". $min_power_path $var(src_path)"
if {$synopsys_program_name == "icc_shell" || $synopsys_program_name == "dc_shell"} {
	set_app_var	alib_library_analysis_path		[dict get $lib_common alib_path]
	set synthetic_library   "dw_foundation.sldb dw_minpower.sldb"
}
if {$synopsys_program_name == "pt_shell"} {
	set synthetic_library   ""
}
dict lappend nhp_predefine ref_mw /share/home/limuhan/Libraries/TSMC28/PLL/
dict lappend nhp_predefine ref_mw /share/home/limuhan/Libraries/TSMC28/ram64x32/
dict lappend nhp_predefine ref_mw /share/home/limuhan/Libraries/TSMC28/tphn28hpcpgv18/
dict lappend nhp_predefine ref_mw /share/home/limuhan/Libraries/TSMC28/tcbn28hpcplusbwp30p140uhvt/

set link_library        "../libs/tcbn28hpcplusbwp30p140uhvttt0p9v25c.db  $synthetic_library"
lappend link_library 	"../libs/ts1n28hpcphvtb64x96m4swbaso_tt0p9v85c.db"
lappend link_library    "../libs/tphn28hpcpgv18tt0p9v1p8v25c.db"
lappend link_library	"../libs/PLLTS28HPMFRAC_BC.db"
set target_library		"../libs/tcbn28hpcplusbwp30p140uhvttt0p9v25c.db"
lappend target_library 	"../libs/ts1n28hpcphvtb64x96m4swbaso_tt0p9v85c.db"
lappend target_library	"../libs/tphn28hpcpgv18tt0p9v1p8v25c.db"
lappend target_library	"../libs/PLLTS28HPMFRAC_BC.db"
set lef_library		[join [dict get $lib_common tech_lef]]
#set clocklist_cts	""			
#set clocklist_mesh	""		



source ../CMD/.dcicc_proc.tcl
if {$synopsys_program_name == "pt_shell" && $pt_shell_mode == "primetime_slave"} { cd $cur_shell_run_path }
if {$synopsys_program_name == "icc_shell" || $synopsys_program_name == "dc_shell"} {
	update_nhp_clockdefine 1
	if {$designopt(fast_mode)} {
		set designopt(power)		false
		set designopt(autoweight)	false
		set designopt(focal_opt)	false
		set designopt(zrt_crt_prior)	false
		set designopt(autobound)	false
		set var(icv,signoff_drc)	false
		set designopt(optimize_vias)	false
	}
}



########################################################################################
######	Show flow settings
########################################################################################
if {$synopsys_program_name == "icc_shell" || $synopsys_program_name == "dc_shell"} {
	set repeat_time 73
	puts [string repeat = $repeat_time]
	puts [format "| %-69s |" "DCICCHP FLOW SETTINGS : Version 4.6.0 (2016-10-19)"]
	puts [string repeat - $repeat_time]
	puts [format "| %-20s | %-46s |" "Project" [dict get $nhp_predefine CDSLIB]]
	puts [format "| %-20s | %-46s |" "Process" [dict get $nhp_predefine process]]
	puts [format "| %-20s | %-46s |" "Milkyway" "$var(mw_lib_name,icc)   $var(dc2icc_datatype)"]
	puts [format "| %-20s | %-46s |" "Library" $var(libs)]
	if {[llength $var(libs_finalopt)]>0} {
		puts [format "| %-20s | %-46s |" "Focalopt library" $var(libs_finalopt)]
	}
	set use_floorplan_file 1
	if {[file isfile $var(floorplan)]} {
		puts [format "| %-20s | %-46s |" "Floorplan files" $var(floorplan)]
	} elseif {[llength [dict get $nhp_predefine def_exists]]>0} {
		set index_fp_file 1
		foreach one_def [dict get $nhp_predefine def_exists] {
			if {$index_fp_file} {
				puts [format "| %-20s | %-46s |" "Floorplan files" $one_def]
			} else {
				puts [format "| %-20s | %-46s |" "" $one_def]
			}
			set index_fp_file 0
		}
		foreach one_def [dict get $nhp_predefine def_nonexists] {
			puts [format "| %-20s | %-46s |" "" "${one_def} (doesn't exists)"]
		}
	} else {
		if {$designopt(spg)} {
			puts [format "| %-20s | %-46s |" "Floorplan files" "Auto Exploration Mode"]
		} else {
			puts [format "| %-20s | %-46s |" "Floorplan files" "No File! Auto Floorplan!"]
			set use_floorplan_file 0
		}
	}
	set sys_clock_type ""
	if {[dict size [dict filter $nhp_clockdefine script {key value} {dict get $nhp_clockdefine $key is_mesh}]]>0} {
		lappend sys_clock_type MESH
	}
	if {[dict size [dict filter $nhp_clockdefine script {key value} {dict get $nhp_clockdefine $key is_cts}]]>0} {
		if {$designopt(ccdopt)} {
			if {[string equal $sys_clock_type MESH]} {
				lappend sys_clock_type CTS
			} else {
				set sys_clock_type CCDOPT
			}
		} else {
			lappend sys_clock_type CTS
		}
	}
	puts [format "| %-20s | %-46s |" "Clock Type" $sys_clock_type]
	puts [format "| %-20s | %-46s |" "TOP LAYER" $var(top_layer)]
	if {$use_floorplan_file} {
		puts [format "| %-20s | %-46s |" "SPG" $designopt(spg)]
		if {$designopt(spg)} {
			puts [format "| %-20s | %-46s |" "AUTOBOUND" $designopt(autobound)]
		} else {
			puts [format "| %-20s | %-46s |" "AUTOBOUND" "$designopt(autobound) (no spg no work)"]
		}
	} else {
		puts [format "| %-20s | %-46s |" "SPG" "$designopt(spg) (no def no work)"]
		puts [format "| %-20s | %-46s |" "AUTOBOUND" "$designopt(autobound) (no spg no work)"]
	}
	puts [format "| %-20s | %-46s |" "DC LOOP NUMS" $var(dc_loop_nums)]
	if {$var(dc2icc_datatype)==0} {
		puts [format "| %-20s | %-46s |" "DC => ICC" $var(icc_load_dc_ddc)]
	} elseif {$var(dc2icc_datatype)==1} {
		puts [format "| %-20s | %-46s |" "DC => ICC" "Verilog/SDC/DEF files"]
	} elseif {$var(dc2icc_datatype)==2} {
		puts [format "| %-20s | %-46s |" "DC => ICC" $var(icc_load_dc_mw)]
	} else {
        	puts [format "Script %s:: variable 'var(dc2icc_datatype)' must be one of [0, 1, 2], your setting : %s is wrong!" [string totitle error] $var(dc2icc_datatype)]
        	exit
	}
	#puts [format "| %-20s | %-46s |" "DC MW for ICC" $var(icc_load_dc_mw)]
	puts [format "| %-20s | %-46s |" "POWER OPT" $designopt(power)]
	puts [format "| %-20s | %-46s |" "AUTOWEIGHT OPT" $designopt(autoweight)]
	puts [format "| %-20s | %-46s |" "FOCAL OPT" $designopt(focal_opt)]
	puts [format "| %-20s | %-46s |" "CONGESTION OPT" $designopt(cong)]
	puts [format "| %-20s | %-46s |" "OPTIMIZE VIAS" $designopt(optimize_vias)]
	puts [format "| %-20s | %-46s |" "Route Critical first" $designopt(zrt_crt_prior)]
	#puts [format "| %-20s | %-46s |" "Insert ECO" $var(insert,eco)]
	puts [format "| %-20s | %-46s |" "Insert Spare" $var(insert,spare)]
	puts [format "| %-20s | %-46s |" "Signoff DRC" $var(icv,signoff_drc)]
	puts [format "| %-20s | %-46s |" "Signoff AutoFix DRC" $var(icv,signoff_autofix_drc)]
	puts [format "| %-20s | %-46s |" "Fast Mode" $designopt(fast_mode)]
	if {$var(use_mcmm_flow)} {
		puts [string repeat - $repeat_time]
		set sc_loop_i 0
		foreach each_scenario [dict keys $lib_mcmm] {
			if {[dict get $lib_mcmm $each_scenario active]} {
				set show_scenario_name $each_scenario
			} else {
				set show_scenario_name "$each_scenario (inactive)"
			}
			if {$sc_loop_i==0} {
				puts [format "| %-20s | %-46s |" "Scenarios" $show_scenario_name]
			} else {
				puts [format "| %-20s | %-46s |" "" $show_scenario_name]
			}
			incr sc_loop_i 1
		}
	} else {
		puts [format "| %-20s | %-46s |" "Corner" $var(default_corner)]
		puts [format "| %-20s | %-46s |" "RCtype" $var(default_rctype)]
	}
	puts [string repeat = $repeat_time]
	#if {![regexp -- {2013\.12} $product_version]} {
		#puts [format "Script %s:: current version is : %s, only support 2013.12!" [string totitle error] $product_version]
		#exit
	#}
}

########################################################################################

if {$synopsys_program_name == "dc_shell"} {
	set_app_var cache_read                                  ""
	set_app_var cache_write                                 ""
	set_app_var hdlin_preserve_sequential                   true
	if {$designopt(ccdopt)} { set_app_var power_cg_auto_identify true}
	set rc_noise_model_mode				advanced
	set rc_driver_model_mode			advanced		; # frome K-2016.06, default is : true
	set rc_receiver_model_mode			advanced		; # frome K-2016.06, default is : true
	#set_svf -off

	if {[shell_is_in_topographical_mode]} {
		set_message_info -id TFCHK-012 -limit $var(message_limit)
		set_message_info -id TFCHK-014 -limit $var(message_limit)
		set_message_info -id TFCHK-026 -limit $var(message_limit)
		set_message_info -id TFCHK-035 -limit $var(message_limit)
		set_message_info -id TFCHK-036 -limit $var(message_limit)
		set_message_info -id TFCHK-049 -limit $var(message_limit)
		set_message_info -id TFCHK-072 -limit $var(message_limit)
		set_message_info -id TFCHK-084 -limit $var(message_limit)
		set_message_info -id PWR-429   -limit $var(message_limit)
		set_message_info -id PSYN-850  -limit $var(message_limit)
		set_message_info -id DCT-052   -limit $var(message_limit)
	}
}
set_host_options -max_cores $var(num_cpus)
if {$synopsys_program_name == "dc_shell" && [shell_is_in_topographical_mode]} {
        if {![file isdirectory $var(mw_lib_name,dc) ]} {
		extend_mw_layers
                create_mw_lib -technology [dict get $nhp_predefine tf_file] -mw_reference_library [dict get $nhp_predefine ref_mw] $var(mw_lib_name,dc)
        } else {
                set_mw_lib_reference $var(mw_lib_name,dc) -mw_reference_library [dict get $nhp_predefine ref_mw]
        }
	extend_mw_layers
        open_mw_lib $var(mw_lib_name,dc)
	if {!$var(use_mcmm_flow)} { set_tlu_plus_files -max_tluplus [dict get $nhp_predefine tlu_file] -tech2itf_map [dict get $nhp_predefine itfmap_file] }
	
}

if {$synopsys_program_name == "icc_shell" && ![file isfile $var(dc_dp,flag)]} {
        if {![file isdirectory $var(mw_lib_name,icc) ]} {
		extend_mw_layers
                create_mw_lib -technology [dict get $nhp_predefine tf_file] -mw_reference_library [dict get $nhp_predefine ref_mw] $var(mw_lib_name,icc)
        } else {
                set_mw_lib_reference $var(mw_lib_name,icc) -mw_reference_library [dict get $nhp_predefine ref_mw]
        }
	extend_mw_layers
        open_mw_lib $var(mw_lib_name,icc)
	if {!$var(use_mcmm_flow)} { set_tlu_plus_files -max_tluplus [dict get $nhp_predefine tlu_file] -tech2itf_map [dict get $nhp_predefine itfmap_file] }
	if {!$var(use_def_track)} {
		create_lib_track -dir [dict get $lib_common lib_track dir] \
                	-offset [dict get $lib_common lib_track offset]
	}
	#check_library
	#check_tlu_plus_files
}
if {$synopsys_program_name == "icc_shell"} {
	set_message_info -id TFCHK-014	-limit $var(message_limit)
        set_message_info -id TFCHK-035	-limit $var(message_limit)
        set_message_info -id TFCHK-072	-limit $var(message_limit)
        set_message_info -id TLUP-004	-limit $var(message_limit)
        set_message_info -id TLUP-005	-limit $var(message_limit)
        set_message_info -id ZRT-026	-limit $var(message_limit)
        set_message_info -id ZRT-030	-limit $var(message_limit)
        set_message_info -id ZRT-061	-limit $var(message_limit)
        set_message_info -id ZRT-104	-limit $var(message_limit)
        set_message_info -id ZRT-311	-limit $var(message_limit)
        set_message_info -id CMD-041	-limit $var(message_limit)
        set_message_info -id PSYN-025	-limit $var(message_limit)
        set_message_info -id PSYN-040	-limit $var(message_limit)
        set_message_info -id PSYN-059	-limit $var(message_limit)
        set_message_info -id PSYN-372	-limit $var(message_limit)
        set_message_info -id APL-028	-limit $var(message_limit)
        set_message_info -id APL-070	-limit $var(message_limit)
        set_message_info -id UID-389	-limit $var(message_limit)
        set_message_info -id PWR-429	-limit $var(message_limit)
        set_message_info -id PWR-537	-limit $var(message_limit)
        set_message_info -id CTS-099	-limit $var(message_limit)
        set_message_info -id MWDEFR-140	-limit $var(message_limit)
        set_message_info -id MWDC-040	-limit $var(message_limit)
	set_message_info -id HDUEDIT-106 -limit $var(message_limit)
	set_message_info -id MWUI-031	 -limit $var(message_limit)
	set_message_info -id MWDEFR-126	 -limit $var(message_limit)
	set_message_info -id PGRT-030	 -limit $var(message_limit)
	set_message_info -id APL-007	 -limit $var(message_limit)
}
if {$synopsys_program_name == "pt_shell"} {
	set_message_info -id LNK-041	 -limit $var(message_limit)
	set_message_info -id PWR-020	 -limit $var(message_limit)
	set_message_info -id NED-008	 -limit $var(message_limit)
}

if {$synopsys_program_name == "dc_shell" || $synopsys_program_name == "icc_shell"} {
#	set dontuse cells && remove dontuse attribute from tie1/tie0 cells
}
if {$synopsys_program_name == "icc_shell"} {
	if {![file isfile $var(dc_dp,flag)]} {
		list_mw_cels
		dict set nhp_predefine full_metal_list [get_object_name [get_layers -filter {preferred_direction!=""}]]
		dict set nhp_predefine horizontal_metal_list [get_object_name [get_layers -filter {preferred_direction==horizontal}]]
		dict set nhp_predefine vertical_metal_list [get_object_name [get_layers -filter {preferred_direction==vertical}]]
	}
}
set icc_finalopt ICC
########################################################################################
######	define procedure
########################################################################################
#	alias
alias rpt_max "report_timing -delay max -transition_time -input_pins -capacitance \
		-nets -significant_digits 3 -derate -physical"
alias rpt_min "report_timing -delay min -transition_time -input_pins -capacitance \
		-nets -significant_digits 3 -derate -physical"

# custom procedure
if {$synopsys_program_name == "dc_shell"} {
	source ../CMD/.dc_proc_auto_weights.tcl
	###     create working directories
	if {![file exists DC]} {
        	file mkdir DC
	}
	if {![file exists DC/report]} {
        	file mkdir DC/report
	}
	if {![file exists DC/out]} {
        	file mkdir DC/out
	}
}
if {$synopsys_program_name == "icc_shell"} {
	source ../CMD/.icc_proc_auto_weights.tcl
	###     create working directories
	if {![file isdirectory $icc_finalopt]} {
        	file mkdir $icc_finalopt
	}
	if {![file isdirectory $icc_finalopt/report]} {
        	file mkdir $icc_finalopt/report
	}
	if {![file isdirectory $icc_finalopt/out]} {
        	file mkdir $icc_finalopt/out
	}
}
## replace the remote title.pl to speed up
set esc "\x1b"
set bel "\x7"
