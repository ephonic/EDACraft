################################################################################
# Design Compiler Synthesis Script
# Generated by IC Backend Framework
# Design: FullSystem (TSMC 28nm HPC+)
################################################################################

# ---- Configuration Variables ----
set DESIGN_NAME      "FullSystem_wrapper"
set TOP_MODULE       "FullSystem_wrapper"
set CLOCK_PERIOD     10.0
set CLOCK_NAME       "sys_clk"
set OUTPUT_DIR       "./work/synthesis/DC"

# ---- Host Configuration ----
set_host_options -max_cores 8

# ---- Library Setup ----
# TSMC 28nm HPC+ Standard Cell Libraries
set search_path [concat $search_path [list \
    "/share/home/yangfan/backend_scripts/ImplCraft/syn/libs" \
]]

# Standard cell libraries (typical corner)
set target_library [list \
    "tcbn28hpcplusbwp30p140tt0p9v25c.db" \
]

# I/O libraries
set io_library "tphn28hpcpgv18tt0p9v1p8v25c.db"

# Memory libraries (SRAM)
set memory_libs [list \
    "ts1n28hpcphvtb128x96m4swbaso_180a_tt0p9v25c.db" \
    "ts1n28hpcphvtb128x32m4swbaso_180a_tt0p9v25c.db" \
]

# Link library includes all libraries plus wildcards
set link_library [concat * $target_library $io_library $memory_libs]
set symbol_library {}

# ---- Timing Settings ----
set_app_var timing_enable_multiple_clocks_per_reg true
set_app_var timing_separate_clock_gating_group true
set_app_var timing_use_enhanced_capacitance_modeling true
set_app_var timing_remove_clock_reconvergence_pessimism true
set_app_var timing_crpr_threshold_ps 1.0
set_app_var case_analysis_with_logic_constants true

# ---- Read RTL ----
read_verilog "syn/rtl/FullSystem_wrapper.v"
read_verilog "syn/rtl/FullSystem.v"
read_verilog "syn/rtl/MTS.v"
read_verilog "syn/rtl/Logic_Element.v"
read_verilog "syn/rtl/FF_process.v"
read_verilog "syn/rtl/FFRAM.v"
read_verilog "syn/rtl/DataRAM.v"
read_verilog "syn/rtl/ExterDataRAM.v"
read_verilog "syn/rtl/Inter_Crossbar.v"
read_verilog "syn/rtl/ProgramCounter.v"
read_verilog "syn/rtl/Module_instance.v"
read_verilog "syn/rtl/mux5_to_1.v"
read_verilog "syn/rtl/mux6_to_1.v"

current_design $TOP_MODULE
link
uniquify

# ---- Clock Definition ----
create_clock -name $CLOCK_NAME \
    -period $CLOCK_PERIOD \
    [get_ports $CLOCK_NAME]

# Clock uncertainty (setup/hold)
set_clock_uncertainty -setup 0.5 [get_clocks $CLOCK_NAME]
set_clock_uncertainty -hold  0.3 [get_clocks $CLOCK_NAME]

# Clock transition
set_clock_transition 0.15 [get_clocks $CLOCK_NAME]

# ---- I/O Delays and Drives ----
# Input delays (from external sources)
set_input_delay -clock $CLOCK_NAME -max 3.0 [remove_from_collection [all_inputs] [get_ports $CLOCK_NAME]]
set_input_delay -clock $CLOCK_NAME -min 1.0 [remove_from_collection [all_inputs] [get_ports $CLOCK_NAME]]

# Output delays (to external loads)
set_output_delay -clock $CLOCK_NAME -max 3.0 [all_outputs]
set_output_delay -clock $CLOCK_NAME -min 1.0 [all_outputs]

# Input driving cells (assume driven by buffer)
set_driving_cell -lib_cell "BUFFX4" -pin Z [remove_from_collection [all_inputs] [get_ports $CLOCK_NAME]]

# Output load capacitance
set_load 0.05 [all_outputs]

# ---- Design Rules ----
set_max_fanout 20 [current_design]
set_max_transition 0.5 [current_design]
set_max_capacitance 0.5 [current_design]

# ---- Timing Derate (OCV) ----
set_timing_derate -late 1.05
set_timing_derate -early 0.95

# ---- Compile Options ----
set compile_clock_gating_through_hierarchy true
set compile_enable_register_removal true

# ---- Compile Design ----
puts "INFO: Starting compilation..."
compile_ultra -gate_clock -scan -no_autoungroup -timing_high_effort_script

puts "INFO: Compilation complete"

# ---- Optimization ----
optimize_netlist
report_area -hierarchy

# ---- Generate Reports ----
puts "INFO: Generating reports..."

# Create output directories
file mkdir ${OUTPUT_DIR}/out
file mkdir ${OUTPUT_DIR}/report

# QoR summary
report_qor -significant_digits 4 > ${OUTPUT_DIR}/report/qor.rpt

# Timing reports
report_timing -max_paths 100 \
    -significant_digits 4 \
    -nworst 1 \
    -delay max \
    -sort_by slack \
    > ${OUTPUT_DIR}/report/timing_setup.rpt

report_timing -max_paths 100 \
    -significant_digits 4 \
    -nworst 1 \
    -delay min \
    -sort_by slack \
    > ${OUTPUT_DIR}/report/timing_hold.rpt

# Area report
report_area -hierarchy -nosplit > ${OUTPUT_DIR}/report/area.rpt

# Power report
report_power -nosplit -hierarchy -hier_level 1 > ${OUTPUT_DIR}/report/power.rpt

# Constraint violations
report_constraint -all_violators -significant_digits 4 > ${OUTPUT_DIR}/report/constraint.rpt

# Cell statistics
report_cell > ${OUTPUT_DIR}/report/cell.rpt

# VT distribution
report_threshold_voltage_group > ${OUTPUT_DIR}/report/vt_group.rpt

# Clock report
report_clock > ${OUTPUT_DIR}/report/clock.rpt

# Timing derate report
report_timing_derate > ${OUTPUT_DIR}/report/derate.rpt

# ---- Write Outputs ----
puts "INFO: Writing output files..."

# Change names to Verilog-compatible
change_names -rules verilog -hierarchy

# Write gate-level netlist
write -format verilog \
    -hierarchy \
    -output ${OUTPUT_DIR}/out/${DESIGN_NAME}.v

# Write compiled design database
write -format ddc \
    -hierarchy \
    -output ${OUTPUT_DIR}/out/${DESIGN_NAME}.ddc

# Write SDC constraints
write_sdc -nosplit ${OUTPUT_DIR}/out/${DESIGN_NAME}.sdc

# ---- Summary ----
puts "================================================================================"
puts "Synthesis Complete"
puts "================================================================================"
puts "Design: $DESIGN_NAME"
puts "Output directory: $OUTPUT_DIR"
puts ""
puts "Generated files:"
puts "  - ${OUTPUT_DIR}/out/${DESIGN_NAME}.v     (gate-level netlist)"
puts "  - ${OUTPUT_DIR}/out/${DESIGN_NAME}.ddc   (compiled database)"
puts "  - ${OUTPUT_DIR}/out/${DESIGN_NAME}.sdc   (SDC constraints)"
puts ""
puts "Reports:"
puts "  - ${OUTPUT_DIR}/report/qor.rpt"
puts "  - ${OUTPUT_DIR}/report/timing_setup.rpt"
puts "  - ${OUTPUT_DIR}/report/timing_hold.rpt"
puts "  - ${OUTPUT_DIR}/report/area.rpt"
puts "  - ${OUTPUT_DIR}/report/power.rpt"
puts "  - ${OUTPUT_DIR}/report/constraint.rpt"
puts "================================================================================"

exit
